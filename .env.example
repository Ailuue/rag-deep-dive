# Copy this file to `.env` and fill in the key(s) for the stack you choose.
#
#   cp .env.example .env
#
# NEVER commit your real .env file. It is already in .gitignore.

# ---------------------------------------------------------------------------
# Which provider "stack" should the repo use? RAG is provider-agnostic — pick
# whichever you already have set up from the sibling repos.
#
#   openai  -> OpenAI embeddings + OpenAI chat        (needs OPENAI_API_KEY)
#   claude  -> Voyage AI embeddings + Claude messages (needs ANTHROPIC_API_KEY
#                                                       and VOYAGE_API_KEY)
#
# Default is "openai" (simplest: one key, first-party embeddings).
# ---------------------------------------------------------------------------
PROVIDER=openai

# --- For PROVIDER=openai ---
# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# --- For PROVIDER=claude ---
# Anthropic key (the chat model): https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Voyage key (the embeddings — Anthropic has no first-party embeddings endpoint):
# https://www.voyageai.com/
VOYAGE_API_KEY=pa-your-voyage-key-here
